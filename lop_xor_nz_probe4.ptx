//
// Fourth attempt: PTX-level predication (@%p ...) on pure arithmetic got algebraically combined
// away by ptxas rather than kept as a guarded instruction. Real guarded LOP.NZ instructions come
// from short if/else branches that ptxas if-converts into predication instead of an actual
// branch. This probe structures the xor/setp as a real conditional branch, short enough that
// ptxas should hopefully if-convert it.
//
.version 7.0
.target sm_61
.address_size 64

.visible .entry lop_xor_nz_probe4(
    .param .u64 out,
    .param .u32 pg,
    .param .u32 pa,
    .param .u32 pb
)
{
    .reg .u32 %r<10>;
    .reg .pred %pguard, %presult;
    .reg .u64 %rd<3>;

    ld.param.u64 %rd1, [out];
    cvta.to.global.u64 %rd2, %rd1;

    ld.param.u32 %r1, [pg];
    ld.param.u32 %r2, [pa];
    ld.param.u32 %r3, [pb];

    setp.eq.s32 %pguard, %r1, 0;
    @%pguard bra SKIP;

    xor.b32 %r4, %r2, %r3;
    setp.ne.s32 %presult, %r4, 0;
    selp.u32 %r5, 111, 222, %presult;
    st.global.u32 [%rd2], %r5;
    bra END;

SKIP:
    st.global.u32 [%rd2], 333;

END:
    ret;
}
